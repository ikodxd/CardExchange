# Copy this file to .env and fill in your values

APP_NAME=Card Exchange
SECRET_KEY=your-very-secret-key-min-32-chars
INTERNAL_SECRET=your-internal-services-secret

AUTH_DATABASE_URL=sqlite:///./data/auth.db
ACCESS_TOKEN_EXPIRE_MINUTES=60
STARTING_BALANCE=1000.0

ADMIN_EMAIL=admin@yourdomain.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

CARDS_DATABASE_URL=sqlite:///./data/cards.db
TRADES_DATABASE_URL=sqlite:///./data/trades.db

REDIS_URL=redis://redis:6379/0

AUTH_SERVICE_URL=http://auth:8001
CARDS_SERVICE_URL=http://cards:8002

# SMTP — leave SMTP_USER empty to print reset links to logs
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@cardexchange.com
FRONTEND_URL=https://yourdomain.com
